# Production env values — synced to Pi on deploy. Do not put secrets here.
# Secrets (JWT_SECRET, SMTP_PASS, STRIPE_*) stay only in .env on the Pi and locally.

CLIENT_URL=https://www.skyreachvisuals.co.uk
SMTP_HOST=smtp.ionos.co.uk
SMTP_PORT=465
EMAIL_FROM=support@skyreachvisuals.co.uk
STRIPE_SUCCESS_URL=https://www.skyreachvisuals.co.uk/booking/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://www.skyreachvisuals.co.uk/services
