# Database
DATABASE_URL=postgresql://skyreach:skyreach_pass@localhost:5432/skyreach

# JWT
JWT_SECRET=change-me-to-a-strong-random-string
JWT_EXPIRES_IN=3650d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# URLs
CLIENT_URL=http://localhost:5173
STRIPE_SUCCESS_URL=http://localhost:5173/booking/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5173/services

# SMTP (email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=bookings@skyreachvisuals.co.uk

# Server
PORT=5000
NODE_ENV=development

# Bank transfer (optional — used when sending “Account info” direct invoices)
BANK_ACCOUNT_NAME=
BANK_SORT_CODE=
BANK_ACCOUNT_NUMBER=
# Optional: e.g. use order number as reference
BANK_REFERENCE_HINT=
